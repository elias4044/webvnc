# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to a specific origin in production, e.g. https://vnc.example.com
CORS_ORIGIN=*

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── VNC defaults ──────────────────────────────────────────────────────────────
# These are used to pre-populate the UI (never sent as a secret).
VNC_DEFAULT_HOST=localhost
VNC_DEFAULT_PORT=6080
VNC_DEFAULT_PATH=/
VNC_DEFAULT_ENCRYPT=false

# ── Websockify (built-in WebSocket→TCP proxy) ─────────────────────────────────
# The built-in proxy bridges the browser WebSocket to the raw VNC TCP port.
# noVNC will connect to ws://<host>:WEBSOCKIFY_PORT/ automatically.
WEBSOCKIFY_ENABLED=true
WEBSOCKIFY_PORT=6080
WEBSOCKIFY_HOST=0.0.0.0

# ── Trust proxy ───────────────────────────────────────────────────────────────
# Set to true when deploying behind nginx / traefik / Caddy
TRUST_PROXY=false
