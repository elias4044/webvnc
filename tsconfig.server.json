{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist/server",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "paths": {
      "@server/*": ["src/server/*"]
    }
  },
  "include": ["src/server/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/client"]
}
